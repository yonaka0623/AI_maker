<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="AICharacterMaker.Controls.FooterBar"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Border
        BackgroundColor="#1E1E2E"
        StrokeThickness="0"
        Padding="0,8">
        <Border.StrokeShape>
            <RoundRectangle CornerRadius="16,16,0,0" />
        </Border.StrokeShape>

        <HorizontalStackLayout
            HorizontalOptions="Center"
            Spacing="40">

            <Button
                x:Name="CharaListButton"
                Text="&#xE7EF;"
                FontFamily="OpenSansRegular"
                FontSize="24"
                TextColor="White"
                BackgroundColor="Transparent"
                Clicked="OnCharaListClicked" />

            <Button
                x:Name="CreateButton"
                Text="&#xE710;"
                FontFamily="OpenSansRegular"
                FontSize="24"
                TextColor="White"
                BackgroundColor="Transparent"
                Clicked="OnCreateClicked" />

        </HorizontalStackLayout>
    </Border>
</ContentView>
