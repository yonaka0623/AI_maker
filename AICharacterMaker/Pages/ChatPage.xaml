<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AICharacterMaker.Pages.ChatPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:models="clr-namespace:AICharacterMaker.Models"
    xmlns:local="clr-namespace:AICharacterMaker.Pages"
    BackgroundColor="#1E1E2E"
    Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <local:RoleToAlignmentConverter x:Key="RoleToAlignConverter"/>
            <local:RoleToColorConverter x:Key="RoleToColorConverter"/>
        </ResourceDictionary>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,2*,3*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0"
              ColumnDefinitions="Auto,*"
              Padding="16,12">
            <Button
                Text="←"
                FontSize="18"
                TextColor="White"
                BackgroundColor="Transparent"
                Clicked="OnBackClicked"/>
            <Label
                Grid.Column="1"
                x:Name="CharaNameLabel"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="White"
                VerticalOptions="Center"
                Margin="8,0"/>
        </Grid>

        <!-- VRM Viewer -->
        <WebView
            Grid.Row="1"
            x:Name="VrmWebView"
            BackgroundColor="Transparent"
            Navigating="OnWebViewNavigating"/>

        <!-- Message List -->
        <CollectionView
            Grid.Row="2"
            x:Name="MessageCollection"
            Margin="12,0"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Message">
                    <Grid Margin="0,4">
                        <Border
                            HorizontalOptions="{Binding Role, Converter={StaticResource RoleToAlignConverter}}"
                            BackgroundColor="{Binding Role, Converter={StaticResource RoleToColorConverter}}"
                            Padding="12,8"
                            MaximumWidthRequest="280">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12"/>
                            </Border.StrokeShape>
                            <Label
                                Text="{Binding Text}"
                                TextColor="White"
                                FontSize="14"/>
                        </Border>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Input Bar -->
        <Grid Grid.Row="3"
              ColumnDefinitions="Auto,*,Auto"
              Padding="12,8"
              BackgroundColor="#2A2A3E">
            <Button
                x:Name="MicButton"
                Text="🎤"
                FontSize="22"
                BackgroundColor="Transparent"
                Clicked="OnMicClicked"/>

            <Entry
                Grid.Column="1"
                x:Name="TextInput"
                Placeholder="メッセージを入力..."
                PlaceholderColor="#888"
                TextColor="White"
                BackgroundColor="Transparent"
                Completed="OnSendClicked"
                Margin="8,0"/>

            <Button
                Grid.Column="2"
                Text="送信"
                BackgroundColor="#7C3AED"
                TextColor="White"
                CornerRadius="8"
                FontSize="14"
                Clicked="OnSendClicked"/>
        </Grid>
    </Grid>
</ContentPage>
