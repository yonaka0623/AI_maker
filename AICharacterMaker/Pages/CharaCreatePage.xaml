<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AICharacterMaker.Pages.CharaCreatePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F2F2F7"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,1,*,Auto">

        <!-- ヘッダー -->
        <HorizontalStackLayout Grid.Row="0"
                Padding="16,14"
                Spacing="8">
            <Label Text="← キャラ一覧"
                   TextColor="#007AFF"
                    FontSize="15"
                   VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnBackClicked"/>
                </Label.GestureRecognizers>
            </Label>
            <Label Text="キャラ作成"
                   FontSize="17"
                    FontAttributes="Bold"
                   TextColor="Black"
                    VerticalOptions="Center"/>
        </HorizontalStackLayout>

        <BoxView Grid.Row="1"
                BackgroundColor="#E0E0E0"/>

        <!-- フォーム -->
        <ScrollView Grid.Row="2">
            <VerticalStackLayout Padding="16,20"
                    Spacing="20">

                <!-- キャラの名前 -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="キャラの名前"
                           FontSize="14"
                            FontAttributes="Bold"
                            TextColor="Black"/>
                    <Border Stroke="#CCCCCC"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="White"
                            Padding="12,0">
                        <Entry x:Name="NameEntry"
                               Placeholder="例：ミカ"
                               PlaceholderColor="#AAAAAA"
                               TextColor="Black"
                               BackgroundColor="Transparent"
                               HeightRequest="48"/>
                    </Border>
                </VerticalStackLayout>

                <!-- 性格の一言説明 -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="性格の一言説明"
                           FontSize="14"
                            FontAttributes="Bold"
                            TextColor="Black"/>
                    <Border Stroke="#CCCCCC"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="White"
                            Padding="12,0">
                        <Entry x:Name="ShortDescEntry"
                               Placeholder="例：明るく活発な女の子"
                               PlaceholderColor="#AAAAAA"
                               TextColor="Black"
                               BackgroundColor="Transparent"
                               HeightRequest="48"/>
                    </Border>
                </VerticalStackLayout>

                <!-- 性格 -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="性格"
                           FontSize="14"
                            FontAttributes="Bold"
                            TextColor="Black"/>
                    <Border Stroke="#CCCCCC"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="White"
                            Padding="12,8">
                        <Editor x:Name="PersonalityEditor"
                                Placeholder="例：優しくて少し照れ屋。相手の話をよく聞いてくれる。"
                                PlaceholderColor="#AAAAAA"
                                TextColor="Black"
                                BackgroundColor="Transparent"
                                MinimumHeightRequest="100"
                                AutoSize="TextChanges"/>
                    </Border>
                </VerticalStackLayout>

                <!-- 声 -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="声"
                           FontSize="14"
                            FontAttributes="Bold"
                            TextColor="Black"/>
                    <Border Stroke="#CCCCCC"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="White"
                            Padding="8,0">
                        <Picker x:Name="VoicePicker"
                                Title="選択してください"
                                TextColor="Black"
                                BackgroundColor="Transparent">
                            <Picker.ItemsSource>
                                <x:Array Type="{x:Type x:String}">
                                    <x:String>Mizuki</x:String>
                                    <x:String>Takumi</x:String>
                                    <x:String>Kazuha</x:String>
                                    <x:String>Tomoko</x:String>
                                </x:Array>
                            </Picker.ItemsSource>
                        </Picker>
                    </Border>
                </VerticalStackLayout>

                <!-- 容姿（アイコン） -->
                <VerticalStackLayout Spacing="6">
                    <Label Text="容姿（アイコン）"
                           FontSize="14"
                            FontAttributes="Bold"
                            TextColor="Black"/>
                    <HorizontalStackLayout Spacing="8">
                        <Button Text="ファイルを選択"
                                BackgroundColor="#E0E0E0"
                                TextColor="#333333"
                                CornerRadius="6"
                                FontSize="14"
                                Clicked="OnSelectIconClicked"/>
                        <Label x:Name="IconFileLabel"
                               Text="選択されていません"
                               TextColor="#888888"
                               VerticalOptions="Center"/>
                    </HorizontalStackLayout>
                    <Label Text="※ 今はアイコンのみ。3Dモデルは後で設定できます"
                           TextColor="#007AFF"
                            FontSize="12"/>
                </VerticalStackLayout>

                <!-- エラー -->
                <Label x:Name="ErrorLabel"
                       TextColor="#FF3B30"
                       IsVisible="False"/>

                <ActivityIndicator x:Name="UploadIndicator"
                                   IsRunning="False"
                        IsVisible="False"
                                   Color="#007AFF"/>

            </VerticalStackLayout>
        </ScrollView>

        <!-- 作成ボタン -->
        <Button Grid.Row="3"
                Text="作成"
                BackgroundColor="#CCCCCC"
                TextColor="White"
                CornerRadius="0"
                FontSize="17"
                HeightRequest="56"
                Clicked="OnSaveClicked"/>
    </Grid>
</ContentPage>