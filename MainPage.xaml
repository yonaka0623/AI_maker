<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="AiCharacterMaker.MainPage"
             xmlns:controls="clr-namespace:AiCharacterMaker.Controls" 
             >

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- ヘッダー -->
        <Grid Grid.Row="0" BackgroundColor="White" Padding="16"
              ColumnDefinitions="*,Auto">
            <Label Grid.Column="0" Text="AI Friends"
                   FontSize="20" FontAttributes="Bold" VerticalOptions="Center">
                <Label.GestureRecognizers>
                    <TapGestureRecognizer Tapped="OnLogoutTapped"/>
                </Label.GestureRecognizers>
            </Label>
            <Button Grid.Column="1" x:Name="HeaderButton"
                    Clicked="OnHeaderButtonClicked"/>
        </Grid>

        <!-- キャラ表示エリア（WebView） -->
        <Border Grid.Row="1" Margin="16" BackgroundColor="White"
                StrokeShape="RoundRectangle 12">
            <Grid>
                <!-- VRMモデルあり → WebViewで表示 -->
                <WebView x:Name="VrmWebView" IsVisible="False"/>

                <!-- VRMモデルなし → テキスト表示 -->
                <Label x:Name="CharaStatusLabel"
                       TextColor="Gray" HorizontalOptions="Center"
                       VerticalOptions="Center"/>
            </Grid>
        </Border>

        <!-- 音声操作エリア -->
        <VerticalStackLayout Grid.Row="2" Padding="16"
                             x:Name="VoiceArea" IsVisible="False">
            <Label x:Name="VoiceStateLabel" TextColor="Gray" FontSize="14"
                   Margin="0,0,0,8"/>

            <Button x:Name="VoiceButton"
                    Pressed="OnVoiceButtonPressed"
                    Released="OnVoiceButtonReleased"
                    FontSize="18" HeightRequest="52"/>

            <!-- 認識結果 -->
            <Border x:Name="RecognizedTextBox" IsVisible="False"
                    BackgroundColor="White" StrokeShape="RoundRectangle 8"
                    Padding="12" Margin="0,8,0,0">
                <VerticalStackLayout>
                    <Label Text="認識結果（送信前）" FontSize="12" TextColor="Gray"/>
                    <Label x:Name="RecognizedTextLabel" FontSize="14"/>
                </VerticalStackLayout>
            </Border>

            <!-- AIの返答 -->
            <Border x:Name="AiTextBox" IsVisible="False"
                    BackgroundColor="White" StrokeShape="RoundRectangle 8"
                    Padding="12" Margin="0,8,0,0">
                <VerticalStackLayout>
                    <Label Text="AIの返答" FontSize="12" TextColor="Gray"/>
                    <Label x:Name="AiTextLabel" FontSize="14"/>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
        <!-- フッター -->
        <controls:FooterBar Grid.Row="3"
                            CharacterId="{Binding ResolvedCharacterId}"/>
    </Grid>
</ContentPage>