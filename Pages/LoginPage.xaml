<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AICharacterMaker.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#1E1E2E"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="*,Auto,*" Padding="32">

        <VerticalStackLayout
            Grid.Row="1"
            Spacing="16">

            <Label
                Text="AI Character Maker"
                FontSize="28"
                FontAttributes="Bold"
                TextColor="White"
                HorizontalOptions="Center"
                Margin="0,0,0,24" />

            <Entry
                x:Name="EmailEntry"
                Placeholder="メールアドレス"
                Keyboard="Email"
                BackgroundColor="#2A2A3E"
                TextColor="White"
                PlaceholderColor="#888"
                Margin="0,4" />

            <Entry
                x:Name="PasswordEntry"
                Placeholder="パスワード"
                IsPassword="True"
                BackgroundColor="#2A2A3E"
                TextColor="White"
                PlaceholderColor="#888"
                Margin="0,4" />

            <Label
                x:Name="ErrorLabel"
                TextColor="#FF6B6B"
                IsVisible="False"
                HorizontalOptions="Center" />

            <Button
                Text="ログイン"
                BackgroundColor="#7C3AED"
                TextColor="White"
                CornerRadius="8"
                Margin="0,8,0,0"
                Clicked="OnLoginClicked" />

            <Button
                Text="新規登録"
                BackgroundColor="Transparent"
                TextColor="#A78BFA"
                BorderColor="#7C3AED"
                BorderWidth="1"
                CornerRadius="8"
                Clicked="OnRegisterClicked" />

            <ActivityIndicator
                x:Name="LoadingIndicator"
                IsRunning="False"
                IsVisible="False"
                Color="#7C3AED"
                HorizontalOptions="Center" />

        </VerticalStackLayout>
    </Grid>
</ContentPage>
