<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AICharacterMaker.Pages.CharaCreatePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#1E1E2E"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="Auto,*" Padding="16,12">
            <Button
                Text="←"
                FontSize="18"
                TextColor="White"
                BackgroundColor="Transparent"
                Clicked="OnBackClicked" />
            <Label
                Grid.Column="1"
                Text="キャラクター作成"
                FontSize="18"
                FontAttributes="Bold"
                TextColor="White"
                VerticalOptions="Center"
                Margin="8,0" />
        </Grid>

        <!-- Form -->
        <ScrollView Grid.Row="1" Padding="20,0">
            <VerticalStackLayout Spacing="16">

                <VerticalStackLayout Spacing="4">
                    <Label Text="キャラクター名 *" TextColor="#CCC" FontSize="13" />
                    <Entry
                        x:Name="NameEntry"
                        Placeholder="例: さくら"
                        BackgroundColor="#2A2A3E"
                        TextColor="White"
                        PlaceholderColor="#888" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="性格・設定 *" TextColor="#CCC" FontSize="13" />
                    <Editor
                        x:Name="PersonalityEditor"
                        Placeholder="例: 明るくて元気な女の子。語尾に「〜だよ！」をつける。"
                        BackgroundColor="#2A2A3E"
                        TextColor="White"
                        PlaceholderColor="#888"
                        MinimumHeightRequest="100"
                        AutoSize="TextChanges" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="4">
                    <Label Text="音声 (AWS Polly)" TextColor="#CCC" FontSize="13" />
                    <Picker
                        x:Name="VoicePicker"
                        TextColor="White"
                        BackgroundColor="#2A2A3E"
                        TitleColor="#888"
                        Title="音声を選択">
                        <Picker.ItemsSource>
                            <x:Array Type="{x:Type x:String}">
                                <x:String>Mizuki</x:String>
                                <x:String>Takumi</x:String>
                                <x:String>Kazuha</x:String>
                                <x:String>Tomoko</x:String>
                            </x:Array>
                        </Picker.ItemsSource>
                    </Picker>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="8">
                    <Label Text="VRMファイル" TextColor="#CCC" FontSize="13" />
                    <Label
                        x:Name="VrmFileLabel"
                        Text="ファイルが選択されていません"
                        TextColor="#888"
                        FontSize="13" />
                    <Button
                        Text="VRMファイルを選択"
                        BackgroundColor="#374151"
                        TextColor="White"
                        CornerRadius="8"
                        Clicked="OnSelectVrmClicked" />
                    <ActivityIndicator
                        x:Name="UploadIndicator"
                        IsRunning="False"
                        IsVisible="False"
                        Color="#7C3AED" />
                </VerticalStackLayout>

                <Label
                    x:Name="ErrorLabel"
                    TextColor="#FF6B6B"
                    IsVisible="False" />

            </VerticalStackLayout>
        </ScrollView>

        <!-- Save Button -->
        <Button
            Grid.Row="2"
            Text="作成する"
            BackgroundColor="#7C3AED"
            TextColor="White"
            CornerRadius="0"
            FontSize="16"
            HeightRequest="52"
            Clicked="OnSaveClicked" />
    </Grid>
</ContentPage>
