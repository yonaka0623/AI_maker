<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="AICharacterMaker.Pages.CharaListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:AICharacterMaker.Controls"
    xmlns:models="clr-namespace:AICharacterMaker.Models"
    BackgroundColor="#1E1E2E"
    Shell.NavBarIsVisible="False">

    <Grid RowDefinitions="Auto,*,Auto">

        <!-- Header -->
        <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Padding="20,16">
            <Label
                Text="キャラクター一覧"
                FontSize="22"
                FontAttributes="Bold"
                TextColor="White"
                VerticalOptions="Center" />
            <Button
                Grid.Column="1"
                Text="ログアウト"
                FontSize="12"
                TextColor="#A78BFA"
                BackgroundColor="Transparent"
                Clicked="OnLogoutClicked" />
        </Grid>

        <!-- Character List -->
        <CollectionView
            Grid.Row="1"
            x:Name="CharaCollection"
            Margin="16,0"
            SelectionMode="None">

            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="8">
                    <Label Text="キャラクターがいません" TextColor="#888" FontSize="16" />
                    <Label Text="＋ボタンで追加してください" TextColor="#666" FontSize="13" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>

            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Character">
                    <SwipeView>
                        <SwipeView.RightItems>
                            <SwipeItems>
                                <SwipeItem
                                    Text="削除"
                                    BackgroundColor="#DC2626"
                                    Invoked="OnDeleteSwipeInvoked" />
                            </SwipeItems>
                        </SwipeView.RightItems>

                        <Border
                            BackgroundColor="#2A2A3E"
                            Stroke="#3D3D5C"
                            StrokeThickness="1"
                            Margin="0,6"
                            Padding="16">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="12" />
                            </Border.StrokeShape>

                            <Grid ColumnDefinitions="*,Auto">
                                <VerticalStackLayout Spacing="4">
                                    <Label
                                        Text="{Binding Name}"
                                        FontSize="18"
                                        FontAttributes="Bold"
                                        TextColor="White" />
                                    <Label
                                        Text="{Binding Personality}"
                                        FontSize="13"
                                        TextColor="#AAA"
                                        LineBreakMode="TailTruncation"
                                        MaxLines="2" />
                                </VerticalStackLayout>

                                <Button
                                    Grid.Column="1"
                                    Text="▶"
                                    FontSize="20"
                                    TextColor="#7C3AED"
                                    BackgroundColor="Transparent"
                                    CommandParameter="{Binding .}"
                                    Clicked="OnStartChatClicked" />
                            </Grid>
                        </Border>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Footer -->
        <controls:FooterBar Grid.Row="2" />
    </Grid>
</ContentPage>
