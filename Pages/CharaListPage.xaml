<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:AiCharacterMaker.Models"
             xmlns:controls="clr-namespace:AiCharacterMaker.Controls"
             x:Class="AiCharacterMaker.Pages.CharaListPage">

    <Grid RowDefinitions="Auto,*,Auto,Auto">

        <!-- ヘッダー -->
        <VerticalStackLayout Grid.Row="0" BackgroundColor="White" Padding="16">
            <Label Text="キャラ一覧" FontSize="20" FontAttributes="Bold"
                   HorizontalOptions="Center"/>

            <!-- 並び替えボタン -->
            <Grid ColumnDefinitions="*,*" ColumnSpacing="8" Margin="0,12,0,0">
                <Button Grid.Column="0" x:Name="SortDescButton" Text="新しい順"
                        Clicked="OnSortDescClicked"/>
                <Button Grid.Column="1" x:Name="SortAscButton" Text="古い順"
                        BackgroundColor="#E5E7EB" TextColor="Black"
                        Clicked="OnSortAscClicked"/>
            </Grid>
        </VerticalStackLayout>

        <!-- キャラ一覧 -->
        <CollectionView Grid.Row="1" x:Name="CharaListView" Margin="16,8">
            <CollectionView.EmptyView>
                <Label Text="まだキャラが作成されていません"
                       TextColor="Gray" HorizontalOptions="Center"
                       Margin="0,32,0,0"/>
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:Character">
                    <Border x:Name="CharaCard" Margin="0,0,0,12" Padding="12"
                            BackgroundColor="White" StrokeShape="RoundRectangle 10">
                        <Grid ColumnDefinitions="56,*,Auto" ColumnSpacing="12">

                            <!-- アイコン -->
                            <Border Grid.Column="0" WidthRequest="56" HeightRequest="56"
                                    StrokeShape="RoundRectangle 28" BackgroundColor="#D1D5DB">
                                <Image Source="{Binding IconUrl}" Aspect="AspectFill"
                                       IsVisible="{Binding IconUrl, Converter={StaticResource NotNullConverter}}"/>
                                <Label Text="NO IMAGE" FontSize="9" TextColor="Gray"
                                       HorizontalOptions="Center" VerticalOptions="Center"
                                       IsVisible="{Binding IconUrl, Converter={StaticResource NullConverter}}"/>
                            </Border>

                            <!-- 名前・性格 -->
                            <VerticalStackLayout Grid.Column="1" VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="16"/>
                                <Label Text="{Binding ShortPersonality}"
                                       TextColor="#4B5563" FontSize="13"/>
                            </VerticalStackLayout>

                            <!-- 編集ボタン -->
                            <Button Grid.Column="2" Text="編集"
                                    BackgroundColor="#E5E7EB" TextColor="Black"
                                    FontSize="12" Padding="8,4"
                                    CommandParameter="{Binding Id}"
                                    Clicked="OnEditClicked"/>
                        </Grid>
                        <Border.GestureRecognizers>
                            <TapGestureRecognizer CommandParameter="{Binding Id}"
                                                  Tapped="OnCharaTapped"/>
                        </Border.GestureRecognizers>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- 作成ボタン -->
        <Button Grid.Row="2" Text="＋ 新しいキャラを作成"
                BackgroundColor="#22C55E" TextColor="White"
                FontSize="18" HeightRequest="52" Margin="16,0"
                Clicked="OnCreateClicked"/>

        <!-- フッター -->
        <controls:FooterBar Grid.Row="3" x:Name="Footer"/>

    </Grid>
</ContentPage>